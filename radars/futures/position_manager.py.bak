"""
WhaleX Prime — Futures Position Manager v2
- Trailing Stop ديناميكي
- هروب تكتيكي استباقي
- كشف انفجار سعري
- إحصائيات الإشارات
- رسائل واضحة (ربح/خسارة/هروب تكتيكي)
"""
from __future__ import annotations
import asyncio, logging, time
from dataclasses import dataclass, field
from typing import Optional
from enum import Enum

log = logging.getLogger("position_manager")

class ExitReason(Enum):
    SL_HIT      = "sl_hit"
    TP1_HIT     = "tp1_hit"
    TP2_HIT     = "tp2_hit"
    TP3_HIT     = "tp3_hit"
    EXPLOSION   = "explosion"
    TACTICAL    = "tactical_exit"

@dataclass
class Position:
    id: str
    user_id: str
    symbol: str
    direction: str
    entry: float
    amount: float
    leverage: float
    sl: float; tp1: float; tp2: float; tp3: float
    tier: str = "B"
    tp1_hit: bool = False
    tp2_hit: bool = False
    tp3_hit: bool = False
    trailing_active: bool = False
    trailing_sl: float = 0.0
    explosion_mode: bool = False
    explosion_extreme: float = 0.0
    peak_price: float = 0.0
    status: str = "open"
    opened_at: int = field(default_factory=lambda: int(time.time()))
    last_warned: int = 0

# ─── STATS ─────────────────────────────────────────────────────
STATS = {
    "total": 0, "wins": 0, "losses": 0, "tactical": 0,
    "tp1_count": 0, "tp2_count": 0, "tp3_count": 0, "explosion_count": 0,
    "total_pnl_pct": 0.0,
}

def update_stats(exit_reason: ExitReason, pnl_pct: float):
    STATS["total"] += 1
    STATS["total_pnl_pct"] += pnl_pct
    if exit_reason == ExitReason.SL_HIT and pnl_pct < 0:
        STATS["losses"] += 1
    elif exit_reason == ExitReason.TACTICAL:
        STATS["tactical"] += 1
        if pnl_pct > 0: STATS["wins"] += 1
    else:
        STATS["wins"] += 1
        if exit_reason == ExitReason.TP1_HIT: STATS["tp1_count"] += 1
        elif exit_reason == ExitReason.TP2_HIT: STATS["tp2_count"] += 1
        elif exit_reason in (ExitReason.TP3_HIT, ExitReason.EXPLOSION): STATS["tp3_count"] += 1

def get_stats_msg():
    t = STATS["total"]
    if t == 0: return "لا توجد إحصائيات بعد"
    wr = STATS["wins"]/t*100
    avg = STATS["total_pnl_pct"]/t
    return (
        f"📊 <b>إحصائيات WhaleX Futures</b>\n{'─'*24}\n"
        f"إجمالي الإشارات: <b>{t}</b>\n"
        f"رابحة: <b>{STATS['wins']}</b> | خاسرة: <b>{STATS['losses']}</b>\n"
        f"هروب تكتيكي: <b>{STATS['tactical']}</b>\n"
        f"نسبة الفوز: <b>{wr:.1f}%</b>\n"
        f"متوسط الربح: <b>{avg:+.2f}%</b>\n"
        f"{'─'*24}\n"
        f"TP1: {STATS['tp1_count']} | TP2: {STATS['tp2_count']} | TP3+: {STATS['tp3_count']}"
    )

# ─── STORE ─────────────────────────────────────────────────────
ACTIVE: dict[str, Position] = {}

async def add_position(pos: Position):
    pos.peak_price = pos.entry
    ACTIVE[pos.id] = pos
    log.info("Position added: %s %s @%.6f", pos.symbol, pos.direction, pos.entry)

async def remove_position(pos_id: str):
    ACTIVE.pop(pos_id, None)

# ─── PRICE ─────────────────────────────────────────────────────
async def get_price(symbol: str) -> Optional[float]:
    try:
        import httpx
        sym = symbol.replace("/","").replace("-","")
        if not sym.endswith("USDT"): sym+="USDT"
        async with httpx.AsyncClient(timeout=5) as c:
            r = await c.get(f"https://fapi.binance.com/fapi/v1/ticker/price?symbol={sym}")
            return float(r.json()["price"])
    except: return None

async def get_order_book(symbol: str) -> dict:
    """جلب Order Book للتحليل"""
    try:
        import httpx
        sym = symbol.replace("/","").replace("-","")
        if not sym.endswith("USDT"): sym+="USDT"
        async with httpx.AsyncClient(timeout=5) as c:
            r = await c.get(f"https://fapi.binance.com/fapi/v1/depth?symbol={sym}&limit=20")
            d = r.json()
            bids = [(float(b[0]), float(b[1])) for b in d.get("bids",[])]
            asks = [(float(a[0]), float(a[1])) for a in d.get("asks",[])]
            bid_vol = sum(v for _,v in bids)
            ask_vol = sum(v for _,v in asks)
            return {"bid_vol": bid_vol, "ask_vol": ask_vol,
                    "ratio": bid_vol/ask_vol if ask_vol else 1,
                    "top_bid": bids[0][0] if bids else 0,
                    "top_ask": asks[0][0] if asks else 0}
    except: return {}

async def get_long_short_ratio(symbol: str) -> float:
    """نسبة Long/Short من Binance"""
    try:
        import httpx
        sym = symbol.replace("/","").replace("-","")
        if not sym.endswith("USDT"): sym+="USDT"
        async with httpx.AsyncClient(timeout=5) as c:
            r = await c.get(f"https://fapi.binance.com/futures/data/globalLongShortAccountRatio?symbol={sym}&period=5m&limit=2")
            d = r.json()
            if len(d) >= 2:
                return float(d[-1]["longShortRatio"]) - float(d[-2]["longShortRatio"])
            return 0
    except: return 0

# ─── NOTIFY ─────────────────────────────────────────────────────
async def notify(user_id: str, msg: str):
    try:
        from db.database import get_session, User
        from services.telegram import send_message
        db = get_session()
        try:
            u = db.query(User).filter(User.id == user_id).first()
            if u and u.tg_chat_id:
                await send_message(u.tg_chat_id, msg)
        finally:
            db.close()
    except Exception as e:
        log.error("notify: %s", e)

# ─── TACTICAL EXIT DETECTOR ────────────────────────────────────
async def should_tactical_exit(pos: Position, price: float, ob: dict, ls_change: float) -> tuple[bool, str]:
    """كشف هل يجب الهروب التكتيكي"""
    is_long = pos.direction == "LONG"
    reasons = []

    # 1. Order Book جدار ضخم
    if ob:
        ratio = ob.get("ratio", 1)
        if is_long and ratio < 0.3:
            reasons.append("جدار بيع ضخم في Order Book")
        elif not is_long and ratio > 3.0:
            reasons.append("جدار شراء ضخم في Order Book")

    # 2. Long/Short Ratio انقلب
    if is_long and ls_change < -0.3:
        reasons.append("Long/Short Ratio انقلب هبوطي")
    elif not is_long and ls_change > 0.3:
        reasons.append("Long/Short Ratio انقلب صعودي")

    # 3. تحرك عكس الاتجاه بدون وصول TP
    pnl = (price-pos.entry)/pos.entry*100 * (1 if is_long else -1)
    if not pos.tp1_hit:
        if pnl < -2.0 and pnl > -3.0:  # خسارة بين 2-3% قبل SL
            reasons.append(f"تراجع قوي {pnl:.1f}% — هروب قبل SL")

    return len(reasons) > 0, " | ".join(reasons)

# ─── EXPLOSION DETECTOR ────────────────────────────────────────
def is_explosion(pos: Position, price: float) -> bool:
    """كشف انفجار سعري"""
    is_long = pos.direction == "LONG"
    move = (price-pos.entry)/pos.entry*100 * (1 if is_long else -1)
    # انفجار = تجاوز TP3 بأكثر من 20%
    tp3_move = (pos.tp3-pos.entry)/pos.entry*100 * (1 if is_long else -1)
    return move > tp3_move * 1.2

def reached_peak(pos: Position, price: float) -> bool:
    """كشف وصول القمة (للـ LONG) أو القاع (للـ SHORT)"""
    is_long = pos.direction == "LONG"
    if is_long:
        # القمة = السعر تراجع بأكثر من 3% من أعلى نقطة
        return pos.peak_price > 0 and price < pos.peak_price * 0.97
    else:
        # القاع = السعر ارتفع بأكثر من 3% من أدنى نقطة
        return pos.peak_price > 0 and price > pos.peak_price * 1.03

# ─── MAIN MONITOR ──────────────────────────────────────────────
async def monitor_position(pos: Position):
    price = await get_price(pos.symbol)
    if not price: return

    is_long = pos.direction == "LONG"
    pnl_pct = (price-pos.entry)/pos.entry*100 * (1 if is_long else -1)

    # تحديث القمة/القاع
    if is_long:
        if price > pos.peak_price: pos.peak_price = price
    else:
        if pos.peak_price == 0 or price < pos.peak_price: pos.peak_price = price

    # ─ وضع الانفجار السعري ─
    if pos.explosion_mode:
        if reached_peak(pos, price):
            profit = abs(pnl_pct)
            msg = (
                f"💥 <b>إغلاق بعد الانفجار السعري — {pos.symbol}</b>\n{'─'*24}\n"
                f"{'📈' if is_long else '📉'} الاتجاه: <b>{pos.direction}</b>\n"
                f"🏆 الربح الإجمالي: <b>+{profit:.2f}%</b>\n"
                f"💰 تم الإغلاق عند {'القمة' if is_long else 'القاع'}: <code>{price}</code>\n"
                f"⚡ <i>استفدنا من كامل الانفجار السعري</i>"
            )
            await notify(pos.user_id, msg)
            update_stats(ExitReason.EXPLOSION, profit)
            pos.status = "closed"; await remove_position(pos.id)
        return

    # ─ جلب بيانات إضافية للتحليل ─
    ob = await get_order_book(pos.symbol)
    ls_change = await get_long_short_ratio(pos.symbol)

    # ─ SL ─
    current_sl = pos.trailing_sl if pos.trailing_active and pos.trailing_sl > 0 else pos.sl
    sl_hit = (price <= current_sl) if is_long else (price >= current_sl)
    if sl_hit:
        if pnl_pct > 0:
            # SL ضرب بعد تحريكه = ربح
            tp_reached = "TP2" if pos.tp2_hit else "TP1" if pos.tp1_hit else "TP1"
            profit = abs(pnl_pct)
            msg = (
                f"✅ <b>تم تحقيق {tp_reached} — {pos.symbol}</b>\n{'─'*24}\n"
                f"{'📈' if is_long else '📉'} <b>{pos.direction}</b>\n"
                f"💰 الربح المحقق: <b>+{profit:.2f}%</b>\n"
                f"🛡 تم إغلاق الصفقة عند SL المتحرك: <code>{current_sl}</code>\n"
                f"✅ <i>الصفقة أُغلقت برسالة رابحة</i>"
            )
            reason = ExitReason.TP2_HIT if pos.tp2_hit else ExitReason.TP1_HIT
            update_stats(reason, profit)
        else:
            loss = abs(pnl_pct)
            msg = (
                f"🔴 <b>وقف الخسارة — {pos.symbol}</b>\n{'─'*24}\n"
                f"{'📈' if is_long else '📉'} <b>{pos.direction}</b>\n"
                f"📉 الخسارة: <b>-{loss:.2f}%</b>\n"
                f"💰 سعر الخروج: <code>{price}</code>\n"
                f"⚠️ <i>تم تفعيل وقف الخسارة</i>"
            )
            update_stats(ExitReason.SL_HIT, -loss)
        await notify(pos.user_id, msg)
        pos.status = "closed"; await remove_position(pos.id)
        return

    # ─ TP1 ─
    tp1_hit = (price >= pos.tp1) if is_long else (price <= pos.tp1)
    if tp1_hit and not pos.tp1_hit:
        pos.tp1_hit = True; pos.trailing_active = True
        pos.trailing_sl = pos.entry; profit = abs(pnl_pct)
        msg = (
            f"🟡 <b>TP1 وصل — {pos.symbol}</b>\n{'─'*24}\n"
            f"{'📈' if is_long else '📉'} <b>{pos.direction}</b>\n"
            f"✅ الربح: <b>+{profit:.2f}%</b>\n"
            f"🎯 TP2: <code>{pos.tp2}</code> | TP3: <code>{pos.tp3}</code>\n"
            f"🛡 SL تحرّك للدخول: <code>{pos.entry}</code>\n"
            f"💡 <i>الربح مضمون الآن — نطارد TP2</i>"
        )
        await notify(pos.user_id, msg)
        log.info("TP1: %s +%.2f%%", pos.symbol, profit)

    # ─ TP2 ─
    tp2_hit = (price >= pos.tp2) if is_long else (price <= pos.tp2)
    if tp2_hit and pos.tp1_hit and not pos.tp2_hit:
        pos.tp2_hit = True; pos.trailing_sl = pos.tp1; profit = abs(pnl_pct)
        msg = (
            f"🟠 <b>TP2 وصل — {pos.symbol}</b>\n{'─'*24}\n"
            f"{'📈' if is_long else '📉'} <b>{pos.direction}</b>\n"
            f"🎉 الربح: <b>+{profit:.2f}%</b>\n"
            f"🎯 TP3: <code>{pos.tp3}</code>\n"
            f"🛡 SL تحرّك فوق TP1: <code>{pos.tp1}</code>\n"
            f"💡 <i>نطارد TP3 الآن</i>"
        )
        await notify(pos.user_id, msg)
        log.info("TP2: %s +%.2f%%", pos.symbol, profit)

    # ─ TP3 ─
    tp3_hit = (price >= pos.tp3) if is_long else (price <= pos.tp3)
    if tp3_hit and pos.tp2_hit and not pos.tp3_hit:
        pos.tp3_hit = True; profit = abs(pnl_pct)
        # كشف انفجار سعري
        if is_explosion(pos, price):
            pos.explosion_mode = True
            pos.explosion_extreme = price
            msg = (
                f"⚡ <b>انفجار سعري — {pos.symbol}</b>\n{'─'*24}\n"
                f"{'📈' if is_long else '📉'} <b>{pos.direction}</b>\n"
                f"🚀 الربح حتى الآن: <b>+{profit:.2f}%</b>\n"
                f"⚡ <b>تجاوزنا TP3 — نتابع الانفجار!</b>\n"
                f"🔍 <i>سنغلق عند {'القمة' if is_long else 'القاع'}</i>"
            )
            await notify(pos.user_id, msg)
        else:
            msg = (
                f"💎 <b>TP3 وصل — {pos.symbol}</b>\n{'─'*24}\n"
                f"{'📈' if is_long else '📉'} <b>{pos.direction}</b>\n"
                f"🏆 الربح الكامل: <b>+{profit:.2f}%</b>\n"
                f"✅ تم إغلاق الصفقة بالكامل\n"
                f"🎊 <i>إشارة WhaleX Prime ناجحة!</i>"
            )
            await notify(pos.user_id, msg)
            update_stats(ExitReason.TP3_HIT, profit)
            pos.status = "closed"; await remove_position(pos.id)
        return

    # ─ Trailing Stop ─
    if pos.trailing_active and pos.trailing_sl > 0:
        if is_long:
            new_sl = price - (pos.tp1-pos.entry)*0.5
            if new_sl > pos.trailing_sl: pos.trailing_sl = new_sl; pos.sl = new_sl
        else:
            new_sl = price + (pos.entry-pos.tp1)*0.5
            if new_sl < pos.trailing_sl: pos.trailing_sl = new_sl; pos.sl = new_sl

    # ─ هروب تكتيكي ─
    now = int(time.time())
    if now - pos.last_warned > 300:  # كل 5 دقائق max
        tactical, reason = await should_tactical_exit(pos, price, ob, ls_change)
        if tactical:
            pos.last_warned = now
            tp_status = "TP2" if pos.tp2_hit else "TP1" if pos.tp1_hit else "قبل TP1"
            profit_str = f"+{abs(pnl_pct):.2f}%" if pnl_pct > 0 else f"{pnl_pct:.2f}%"
            msg = (
                f"🏃 <b>هروب تكتيكي — {pos.symbol}</b>\n{'─'*24}\n"
                f"{'📈' if is_long else '📉'} <b>{pos.direction}</b>\n"
                f"📊 الوضع الحالي: <b>{tp_status}</b>\n"
                f"💰 PnL: <b>{profit_str}</b>\n"
                f"⚠️ السبب: {reason}\n"
                f"💡 <i>يُنصح بالخروج الاستباقي</i>"
            )
            await notify(pos.user_id, msg)

async def run_position_manager():
    log.info("Position Manager started")
    while True:
        try:
            positions = list(ACTIVE.values())
            for pos in positions:
                if pos.status == "open":
                    await monitor_position(pos)
                    await asyncio.sleep(0.3)
            if not positions:
                await asyncio.sleep(10)
        except Exception as e:
            log.error("PM error: %s", e)
        await asyncio.sleep(30)
