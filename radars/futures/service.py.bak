"""WhaleX Prime — Futures Radar Service — يراقب كل عملات Binance Futures"""
from __future__ import annotations
import asyncio, logging, time
from typing import Optional
from core.config import get_settings
from radars.futures.engine import Candle, Signal, MarketTier, analyze
from db.database import get_session, Signal as DBSignal

log = logging.getLogger("futures_service")

CANDLES: dict[str,list[Candle]] = {}
LAST_SIGNALS: dict[str,int] = {}
SIGNAL_COOLDOWN = 3600
ALL_SYMBOLS: list[MarketTier] = []

async def fetch_all_futures_symbols() -> list[MarketTier]:
    """جلب كل عملات Futures من Binance وتصنيفها"""
    try:
        import httpx
        async with httpx.AsyncClient(timeout=15) as c:
            # جلب كل العملات
            r = await c.get("https://fapi.binance.com/fapi/v1/exchangeInfo")
            symbols = [s["symbol"] for s in r.json()["symbols"]
                      if s["status"]=="TRADING" and s["symbol"].endswith("USDT")]
            # جلب الـ 24h ticker
            r2 = await c.get("https://fapi.binance.com/fapi/v1/ticker/24hr")
            vols = {t["symbol"]: float(t["quoteVolume"]) for t in r2.json()}

        # ترتيب حسب الـ volume
        sym_vols = [(s, vols.get(s,0)) for s in symbols]
        sym_vols.sort(key=lambda x: x[1], reverse=True)

        # حساب الحدود الديناميكية
        all_vols = [v for _,v in sym_vols if v > 0]
        if not all_vols: return []

        p80 = all_vols[int(len(all_vols)*0.2)]  # أعلى 20%
        p40 = all_vols[int(len(all_vols)*0.6)]  # أعلى 60%

        tiers = []
        for sym, vol in sym_vols:
            if vol < 5_000_000: continue  # حد أدنى $5M
            if vol >= p80:
                t = MarketTier(sym, vol, "S", max_leverage=50, min_score=5.0, min_confidence=70)
            elif vol >= p40:
                t = MarketTier(sym, vol, "A", max_leverage=25, min_score=4.5, min_confidence=65)
            else:
                t = MarketTier(sym, vol, "B", max_leverage=10, min_score=4.0, min_confidence=60)
            tiers.append(t)

        log.info("Fetched %d symbols — S:%d A:%d B:%d",
            len(tiers),
            sum(1 for t in tiers if t.tier=="S"),
            sum(1 for t in tiers if t.tier=="A"),
            sum(1 for t in tiers if t.tier=="B"))
        return tiers
    except Exception as e:
        log.error("fetch_symbols: %s", e)
        return []

async def fetch_candles(symbol: str, limit=100) -> list[Candle]:
    try:
        import httpx
        url = f"https://fapi.binance.com/fapi/v1/klines?symbol={symbol}&interval=15m&limit={limit}"
        async with httpx.AsyncClient(timeout=10) as c:
            r = await c.get(url)
            return [Candle(int(d[0]),float(d[1]),float(d[2]),float(d[3]),float(d[4]),float(d[5]),float(d[9])) for d in r.json()]
    except Exception as e:
        log.debug("fetch_candles %s: %s", symbol, e)
        return []

async def save_and_broadcast(sig: Signal):
    db = get_session()
    try:
        db_sig = DBSignal(
            radar_type=sig.radar_type, symbol=sig.symbol, direction=sig.direction,
            grade=sig.grade, score=sig.score, confidence=sig.confidence,
            entry=sig.entry, sl=sig.sl, tp1=sig.tp1, tp2=sig.tp2, tp3=sig.tp3,
            leverage=sig.leverage, strategies=sig.strategies,
        )
        db.add(db_sig); db.commit()
        log.info("Signal: %s %s %s conf=%.0f%% tier=%s", sig.symbol, sig.direction, sig.grade, sig.confidence, sig.tier)
        from services.telegram import TG
        await TG.broadcast_signal({
            "radar_type": sig.radar_type, "symbol": sig.symbol, "direction": sig.direction,
            "grade": sig.grade, "confidence": sig.confidence, "entry": sig.entry,
            "sl": sig.sl, "tp1": sig.tp1, "tp2": sig.tp2, "tp3": sig.tp3,
            "leverage": sig.leverage, "strategies": sig.strategies, "tier": sig.tier,
        })
    except Exception as e:
        log.error("save_and_broadcast: %s", e)
    finally:
        db.close()

async def analyze_symbol(tier: MarketTier):
    candles = await fetch_candles(tier.symbol)
    if not candles: return
    CANDLES[tier.symbol] = candles
    sig = analyze(candles, tier.symbol, tier)
    if not sig: return
    last = LAST_SIGNALS.get(tier.symbol, 0)
    if time.time()-last < SIGNAL_COOLDOWN: return
    LAST_SIGNALS[tier.symbol] = int(time.time())
    await save_and_broadcast(sig)

async def run_futures_radar():
    global ALL_SYMBOLS
    log.info("Futures Radar starting...")
    s = get_settings()

    # جلب العملات أول مرة
    ALL_SYMBOLS = await fetch_all_futures_symbols()
    if not ALL_SYMBOLS:
        log.error("No symbols fetched — retrying in 60s")
        await asyncio.sleep(60)
        ALL_SYMBOLS = await fetch_all_futures_symbols()

    if s.telegram_admin_chat_id:
        from services.telegram import send_message
        await send_message(s.telegram_admin_chat_id,
            f"📡 <b>Futures Radar نشط</b>\n"
            f"يراقب <b>{len(ALL_SYMBOLS)}</b> عملة\n"
            f"الفئة S: {sum(1 for t in ALL_SYMBOLS if t.tier=='S')} عملة\n"
            f"الفئة A: {sum(1 for t in ALL_SYMBOLS if t.tier=='A')} عملة\n"
            f"الفئة B: {sum(1 for t in ALL_SYMBOLS if t.tier=='B')} عملة"
        )

    scan_count = 0
    while True:
        try:
            # تحديث قائمة العملات كل 6 ساعات
            if scan_count % 72 == 0:
                ALL_SYMBOLS = await fetch_all_futures_symbols()

            log.info("Scanning %d symbols...", len(ALL_SYMBOLS))
            for tier in ALL_SYMBOLS:
                await analyze_symbol(tier)
                await asyncio.sleep(0.3)

            scan_count += 1
            log.info("Scan #%d complete — next in 5 min", scan_count)
        except Exception as e:
            log.error("Radar loop: %s", e)
        await asyncio.sleep(300)
