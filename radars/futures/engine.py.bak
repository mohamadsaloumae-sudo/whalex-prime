"""WhaleX Prime — Futures Radar Engine v2 — Sniper+Hunter+Dynamic Tiers"""
from __future__ import annotations
import asyncio, logging, time, statistics
from dataclasses import dataclass, field
from typing import Optional

log = logging.getLogger("futures_engine")

@dataclass
class Candle:
    time: int; open: float; high: float; low: float; close: float
    volume: float; buy_volume: float = 0.0

@dataclass
class MarketTier:
    symbol: str; volume_24h: float; tier: str
    max_leverage: float; min_score: float; min_confidence: float

@dataclass
class Signal:
    symbol: str; direction: str; grade: str; score: float; confidence: float
    entry: float; sl: float; tp1: float; tp2: float; tp3: float
    leverage: float; strategies: str; tier: str = "B"
    radar_type: str = "futures"
    timestamp: int = field(default_factory=lambda: int(time.time()))

def ema(data, p):
    if len(data) < p: return [data[-1]]*len(data)
    k = 2/(p+1); e = sum(data[:p])/p; r = [None]*(p-1)+[e]
    for i in range(p, len(data)): e=data[i]*k+e*(1-k); r.append(e)
    return r

def rsi(c, p=14):
    if len(c)<p+1: return 50.0
    g=[max(c[i]-c[i-1],0) for i in range(1,len(c))]
    l=[max(c[i-1]-c[i],0) for i in range(1,len(c))]
    ag=sum(g[-p:])/p; al=sum(l[-p:])/p
    return 100.0 if al==0 else 100-100/(1+ag/al)

def macd(c):
    if len(c)<26: return 0,0,0
    e12=ema(c,12); e26=ema(c,26)
    ml=[a-b for a,b in zip(e12[25:],e26[25:]) if a and b]
    if len(ml)<9: return 0,0,0
    sl=ema(ml,9); m=ml[-1]; s=sl[-1] or 0
    return m,s,m-s

def bollinger(c,p=20):
    if len(c)<p: return c[-1],c[-1],c[-1],0
    w=c[-p:]; mid=sum(w)/p; std=statistics.stdev(w)
    return mid+2*std,mid,mid-2*std,std

def atr(cands,p=14):
    if len(cands)<p+1: return cands[-1].close*0.01
    trs=[max(cands[i].high-cands[i].low,abs(cands[i].high-cands[i-1].close),abs(cands[i].low-cands[i-1].close)) for i in range(1,len(cands))]
    return sum(trs[-p:])/p

def stoch_rsi(c,p=14,s=3):
    if len(c)<p*2: return 50.0,50.0
    rv=[rsi(c[:i+1],p) for i in range(p,len(c))]
    if len(rv)<p: return 50.0,50.0
    w=rv[-p:]; mn,mx=min(w),max(w)
    if mx==mn: return 50.0,50.0
    st=[(r-mn)/(mx-mn)*100 for r in rv[-p:]]
    k=sum(st[-s:])/s; d=sum(st[-s*2:-s])/s if len(st)>=s*2 else k
    return k,d

def cvd(cands,p=20):
    if len(cands)<p: return 0
    return sum(c.buy_volume-(c.volume-c.buy_volume) for c in cands[-p:])

def obi(cands,p=10):
    if len(cands)<p: return 0
    bv=sum(c.buy_volume for c in cands[-p:]); sv=sum(c.volume-c.buy_volume for c in cands[-p:])
    t=bv+sv; return (bv-sv)/t if t else 0

def delta_flow(cands,p=5):
    if len(cands)<p*2: return 0
    r=[c.buy_volume-(c.volume-c.buy_volume) for c in cands[-p:]]
    pv=[c.buy_volume-(c.volume-c.buy_volume) for c in cands[-p*2:-p]]
    return sum(r)/p-sum(pv)/p if pv else 0

def whale_detect(cands,mult=3.0):
    if len(cands)<20: return False
    avg=sum(c.volume for c in cands[-20:-1])/19
    return cands[-1].volume>avg*mult

def vol_spike(cands,p=20,th=2.0):
    if len(cands)<p: return False
    avg=sum(c.volume for c in cands[-p:-1])/(p-1)
    return cands[-1].volume>avg*th

def sniper_entry(cands,direction):
    if len(cands)<5: return False,0
    r=cands[-5:]; lows=[c.low for c in r]; highs=[c.high for c in r]; closes=[c.close for c in r]
    if direction=="LONG":
        ok=closes[-1]>closes[-2] and closes[-2]<=min(lows[:-1])
        q=min((closes[-1]-min(lows))/closes[-1]*100,3.0) if ok else 0
    else:
        ok=closes[-1]<closes[-2] and closes[-2]>=max(highs[:-1])
        q=min((max(highs)-closes[-1])/closes[-1]*100,3.0) if ok else 0
    return ok,q

def hunter_mode(cands,direction):
    if len(cands)<10: return False,0
    closes=[c.close for c in cands]; vols=[c.volume for c in cands]
    avg_v=sum(vols[-20:-1])/19 if len(vols)>=20 else sum(vols)/len(vols)
    prev_low=min(c.low for c in cands[-10:-1]); prev_high=max(c.high for c in cands[-10:-1])
    if direction=="LONG":
        ok=cands[-1].low<prev_low and closes[-1]>prev_low and vols[-1]>avg_v*2
    else:
        ok=cands[-1].high>prev_high and closes[-1]<prev_high and vols[-1]>avg_v*2
    return ok,(2.0 if ok else 0)

def dynamic_params(cands,direction,score,tier):
    price=cands[-1].close; atr_v=atr(cands); pct=atr_v/price
    if pct>0.05: lev=2.0
    elif pct>0.03: lev=4.0
    elif pct>0.02: lev=6.0
    elif pct>0.01: lev=10.0
    elif pct>0.005: lev=15.0
    else: lev=20.0
    lev=min(lev*(1+score/20),tier.max_leverage)
    if direction=="LONG":
        sl=round(price-atr_v*1.5,6); tp1=round(price+atr_v*1.8,6)
        tp2=round(price+atr_v*3.0,6); tp3=round(price+atr_v*5.0,6)
    else:
        sl=round(price+atr_v*1.5,6); tp1=round(price-atr_v*1.8,6)
        tp2=round(price-atr_v*3.0,6); tp3=round(price-atr_v*5.0,6)
    return sl,tp1,tp2,tp3,round(min(lev,tier.max_leverage),1)

def calc_grade(score,conf):
    if score>=9 and conf>=85: return "S"
    if score>=7 and conf>=75: return "A"
    if score>=5 and conf>=65: return "B"
    return "C"

def analyze(candles,symbol,tier):
    if len(candles)<60: return None
    closes=[c.close for c in candles]; price=closes[-1]
    rsi_v=rsi(closes); mv,ms,mh=macd(closes)
    bb_u,bb_m,bb_l,bb_std=bollinger(closes); sk,sd=stoch_rsi(closes)
    cvd_v=cvd(candles); obi_v=obi(candles); dflow=delta_flow(candles)
    whale=whale_detect(candles); vs=vol_spike(candles)
    e20=ema(closes,20)[-1] or price; e50=ema(closes,50)[-1] or price
    sl=ss=0.0; tl=[]; ts=[]

    if rsi_v<28: sl+=2.5; tl.append(f"RSI Oversold {rsi_v:.0f}")
    elif rsi_v<38: sl+=1.5; tl.append(f"RSI Low {rsi_v:.0f}")
    if rsi_v>72: ss+=2.5; ts.append(f"RSI Overbought {rsi_v:.0f}")
    elif rsi_v>62: ss+=1.5; ts.append(f"RSI High {rsi_v:.0f}")
    if mv>ms and mh>0: sl+=1.5; tl.append("MACD Bullish")
    if mv<ms and mh<0: ss+=1.5; ts.append("MACD Bearish")
    if price<=bb_l: sl+=2; tl.append("BB Lower Touch")
    elif price>=bb_u: ss+=2; ts.append("BB Upper Touch")
    if sk<20 and sk>sd: sl+=1.5; tl.append(f"StochRSI Oversold {sk:.0f}")
    if sk>80 and sk<sd: ss+=1.5; ts.append(f"StochRSI Overbought {sk:.0f}")
    if cvd_v>0: sl+=1; tl.append("CVD Bullish")
    else: ss+=1; ts.append("CVD Bearish")
    if obi_v>0.2: sl+=1; tl.append(f"OBI Buy {obi_v:.2f}")
    elif obi_v<-0.2: ss+=1; ts.append(f"OBI Sell {obi_v:.2f}")
    if dflow>0: sl+=1; tl.append("Delta Bullish")
    else: ss+=1; ts.append("Delta Bearish")
    if whale:
        if cvd_v>0: sl+=2.5; tl.append("Whale Accumulation")
        else: ss+=2.5; ts.append("Whale Distribution")
    if vs:
        if cvd_v>0: sl+=1; tl.append("Volume Spike Buy")
        else: ss+=1; ts.append("Volume Spike Sell")
    if price>e20>e50: sl+=0.5; tl.append("Uptrend EMA")
    elif price<e20<e50: ss+=0.5; ts.append("Downtrend EMA")

    direction=score=None; strats=[]
    if sl>=ss and sl>=tier.min_score: direction="LONG"; score=sl; strats=tl
    elif ss>sl and ss>=tier.min_score: direction="SHORT"; score=ss; strats=ts
    if not direction: return None

    sniper_ok,sniper_s=sniper_entry(candles,direction)
    if sniper_ok: score+=sniper_s; strats.append(f"Sniper Entry")
    hunter_ok,hunter_s=hunter_mode(candles,direction)
    if hunter_ok: score+=hunter_s; strats.append(f"Hunter Mode")

    conf=min(score/16*100,99)
    if conf<tier.min_confidence: return None
    g=calc_grade(score,conf)
    sl_p,tp1,tp2,tp3,lev=dynamic_params(candles,direction,score,tier)
    return Signal(symbol=symbol,direction=direction,grade=g,score=round(score,1),
        confidence=round(conf,1),entry=price,sl=sl_p,tp1=tp1,tp2=tp2,tp3=tp3,
        leverage=lev,strategies="\n".join(strats[:6]),tier=tier.tier)
